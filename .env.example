# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- CMS Backend (choose one) ---
# For GitHub-backed CMS on Vercel:
# - Set this as a Vercel *Client* env var (VITE_...) so the frontend uses GitHubCMSService.
VITE_CMS_BACKEND="github"

# Optional (testing only): bypass `/admin` password screen on the client.
# Do NOT enable in production.
# VITE_INSECURE_ADMIN="true"

# --- Server env (Vercel Functions) ---
# Used by `api/site-details.ts` to read/write `src/data/siteDetails.json` in GitHub.
ADMIN_PASSWORD="CHANGE_ME"
GITHUB_TOKEN="ghp_or_fine_grained_token"
GITHUB_OWNER="your-github-org-or-username"
GITHUB_REPO="your-repo-name"
GITHUB_BRANCH="main"
GITHUB_CONTENT_PATH="src/data/siteDetails.json"

# Optional (testing only): bypass API auth for POST requests in non-production Vercel envs.
# This is ignored when `VERCEL_ENV=production`.
# ALLOW_INSECURE_ADMIN="true"
